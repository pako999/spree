<%# Order confirmed heading %>
<p style="margin: 0 0 6px;">
  <span class="status-badge">&#10003; Order Confirmed</span>
</p>

<h1 style="margin-top: 14px; margin-bottom: 6px;">
  <%= Spree.t('order_mailer.confirm_email.dear_customer', name: name_for(@order)) %>
</h1>

<p style="margin-bottom: 24px;">
  Thank you for your order. Please find below a summary of your purchase for your records.
</p>

<%# Order info box %>
<div class="info-box">
  <p>
    <strong>Order <%= @order.number %></strong> &nbsp;&bull;&nbsp;
    Placed <%= @order.completed_at.strftime("%B %-d, %Y") rescue "" %>
    &nbsp;&bull;&nbsp;
    <a href="<%= "#{current_store.formatted_url}/#{I18n.locale}/account/orders/#{@order.number}" %>" style="color: #1E40AF; font-weight: 600;">View order &rarr;</a>
  </p>
</div>

<%# Items table %>
<h3>Order Summary</h3>

<table class="purchase" role="presentation">
  <tr>
    <td colspan="2">
      <%= render 'spree/shared/purchased_items_table', line_items: @order.line_items, order: @order %>
    </td>
  </tr>
</table>

<%# Shipping address %>
<% if @order.ship_address.present? %>
<hr class="section-divider">
<table width="100%" cellpadding="0" cellspacing="0" role="presentation">
  <tr>
    <td width="50%" style="vertical-align: top; padding-right: 16px;">
      <h3>Ship To</h3>
      <p style="margin: 0; line-height: 1.7;">
        <%= @order.ship_address.full_name %><br>
        <%= @order.ship_address.address1 %><br>
        <% if @order.ship_address.address2.present? %><%= @order.ship_address.address2 %><br><% end %>
        <%= @order.ship_address.city %>, <%= @order.ship_address.zipcode %><br>
        <%= @order.ship_address.country.name %>
      </p>
    </td>
    <td width="50%" style="vertical-align: top; padding-left: 16px;">
      <h3>Payment</h3>
      <p style="margin: 0; line-height: 1.7;">
        <% @order.payments.completed.each do |payment| %>
          <%= payment.payment_method.name %><br>
          <span style="color: #10B981; font-weight: 600;">&#10003; Paid</span>
        <% end %>
      </p>
    </td>
  </tr>
</table>
<% end %>

<%# Shipping notice — no tracking yet %>
<hr class="section-divider">
<div class="attributes_content">
  <p style="margin: 0; font-size: 14px; color: #374151; line-height: 1.7;">
    <strong>What happens next?</strong><br>
    Our team is now preparing your order for dispatch. Once your order has been shipped,
    you will receive a separate confirmation email containing your tracking number
    and carrier details.
  </p>
</div>

<p style="text-align: center; margin-top: 24px; margin-bottom: 0; font-size: 14px; color: #6B7280;">
  Should you have any questions regarding your order, please do not hesitate to contact us at
  <a href="mailto:info@surf-store.com" style="color: #0062FF; font-weight: 500;">info@surf-store.com</a>
  or visit our <a href="<%= "#{current_store.formatted_url}/en/pages/contact" %>" style="color: #0062FF; font-weight: 500;">Help Centre</a>.
</p>
