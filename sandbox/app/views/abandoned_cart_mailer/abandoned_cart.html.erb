<%# Preheader text — shown in inbox preview, hidden in email body %>
<span class="preheader">Your cart is waiting — complete your order before it sells out.</span>

<%# Hero -%>
<table class="purchase" role="presentation" style="width:100%;margin:0 0 24px;">
  <tr>
    <td style="background-color:#0f172a;border-radius:8px;padding:36px 32px;text-align:center;">
      <p style="margin:0 0 6px;font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#94a3b8;">
        Don't miss out
      </p>
      <h1 style="margin:0 0 12px;font-size:26px;font-weight:700;color:#ffffff;line-height:1.3;">
        You left something in your cart
      </h1>
      <p style="margin:0 0 28px;font-size:16px;color:#cbd5e1;line-height:1.6;">
        Your gear is still reserved. Complete your order before it sells out.
      </p>
      <a href="<%= @cart_url %>"
         style="display:inline-block;background-color:#0ea5e9;color:#ffffff;text-decoration:none;font-weight:700;font-size:15px;padding:14px 36px;border-radius:6px;letter-spacing:0.3px;">
        Complete My Order →
      </a>
    </td>
  </tr>
</table>

<%# Cart items -%>
<table class="purchase" role="presentation" style="width:100%;margin:0 0 8px;">
  <tr>
    <td style="padding-bottom:10px;border-bottom:2px solid #e2e8f0;">
      <p style="margin:0;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#94a3b8;">
        Your Cart &nbsp;·&nbsp; <%= @items.size %> <%= @items.size == 1 ? 'item' : 'items' %>
      </p>
    </td>
  </tr>
</table>

<% @items.each do |item| %>
  <table class="purchase" role="presentation" style="width:100%;margin:0;border-bottom:1px solid #f1f5f9;">
    <tr>
      <td style="padding:16px 0;width:80px;vertical-align:top;">
        <% if item[:image_url] %>
          <img src="<%= item[:image_url] %>"
               alt="<%= item[:name] %>"
               width="72" height="72"
               style="width:72px;height:72px;object-fit:cover;border-radius:6px;display:block;background-color:#f8fafc;" />
        <% else %>
          <div style="width:72px;height:72px;border-radius:6px;background-color:#f1f5f9;"></div>
        <% end %>
      </td>
      <td style="padding:16px 0 16px 16px;vertical-align:top;">
        <a href="<%= item[:url] %>" style="text-decoration:none;color:#0f172a;">
          <p style="margin:0 0 3px;font-size:15px;font-weight:600;color:#0f172a;line-height:1.4;"><%= item[:name] %></p>
        </a>
        <% if item[:options] %>
          <p style="margin:0 0 6px;font-size:13px;color:#64748b;"><%= item[:options] %></p>
        <% end %>
        <p style="margin:0;font-size:14px;color:#374151;">
          Qty <%= item[:quantity] %>
          &nbsp;·&nbsp;
          <strong><%= number_to_currency(item[:price], unit: '€', format: '%n %u') %></strong>
        </p>
      </td>
    </tr>
  </table>
<% end %>

<%# CTA repeat -%>
<table class="body-action" role="presentation" style="width:100%;margin:32px 0 8px;">
  <tr>
    <td style="text-align:center;">
      <a href="<%= @cart_url %>"
         style="display:inline-block;background-color:#0f172a;color:#ffffff;text-decoration:none;font-weight:700;font-size:15px;padding:14px 36px;border-radius:6px;">
        Return to Cart
      </a>
    </td>
  </tr>
</table>

<%# Footer note -%>
<table role="presentation" style="width:100%;margin-top:32px;">
  <tr>
    <td style="border-top:1px solid #e2e8f0;padding-top:20px;text-align:center;">
      <p class="sub" style="color:#94a3b8;font-size:12px;margin:0;">
        You're receiving this because you started an order at
        <a href="<%= @store_url %>" style="color:#94a3b8;">surf-store.com</a>.
        If you've changed your mind, simply ignore this email.
      </p>
    </td>
  </tr>
</table>
