<% content_for :page_title do %>
  Stock Sync
<% end %>

<%# ─── Status cards ─────────────────────────────────────────────── %>
<div class="row mb-4">
  <% @job_names.each do |job_name| %>
    <% log = @latest_logs[job_name] %>
    <div class="col-md-6 mb-3">
      <div class="card h-100">
        <div class="card-body">

          <%# Header row: name + status badge %>
          <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
              <h5 class="card-title mb-0"><%= Spree::StockSyncLog::FRIENDLY_NAMES[job_name] %></h5>
              <small class="text-muted"><%= job_name %></small>
            </div>
            <% if log %>
              <% badge_class = log.success? ? 'badge-pill-success' : log.failed? ? 'badge-pill-danger' : 'badge-pill-warning' %>
              <span class="badge <%= badge_class %> text-uppercase"><%= log.status %></span>
            <% else %>
              <span class="badge badge-pill-secondary text-uppercase">never run</span>
            <% end %>
          </div>

          <%# Last run time + duration %>
          <% if log %>
            <div class="text-muted small mb-2">
              Last run: <%= log.started_at.strftime('%d %b %Y %H:%M') %>
              <% if log.duration_seconds %>
                &middot; <%= log.duration_seconds %>s
              <% end %>
            </div>

            <%# Success stats %>
            <% if log.success? %>
              <div class="small">
                <span class="text-muted">Feed:</span> <%= log.total_in_feed || '—' %> &ensp;
                <span class="text-muted">Matched:</span> <%= log.matched || '—' %> &ensp;
                <span class="<%= log.updated.to_i > 0 ? 'text-success fw-semibold' : 'text-muted' %>">
                  Updated: <%= log.updated || 0 %>
                </span> &ensp;
                <span class="text-muted">Unchanged:</span> <%= log.skipped || '—' %>
                <% if log.unmatched.to_i > 0 %>
                  &ensp;<span class="text-warning">Unmatched: <%= log.unmatched %></span>
                <% end %>
              </div>
            <%# Error message %>
            <% elsif log.failed? %>
              <div class="small text-danger mt-1">
                <strong>Error:</strong> <%= log.error_message&.truncate(120) %>
              </div>
            <% end %>
          <% else %>
            <div class="text-muted small mb-2">No sync history yet.</div>
          <% end %>

          <%# Run Now button %>
          <div class="mt-3">
            <%= form_with url: spree.run_admin_stock_syncs_path, method: :post, local: true do |f| %>
              <%= f.hidden_field :job, value: job_name %>
              <%= f.submit 'Run Now',
                    class: 'btn btn-sm btn-primary',
                    data: { confirm: "Queue #{Spree::StockSyncLog::FRIENDLY_NAMES[job_name]} sync now?" } %>
            <% end %>
          </div>

        </div>
      </div>
    </div>
  <% end %>
</div>

<%# ─── Recent history ────────────────────────────────────────────── %>
<div class="card">
  <div class="card-header">
    <h5 class="card-title mb-0">Recent Sync History</h5>
  </div>
  <% if @recent_logs.any? %>
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="bg-light">
          <tr>
            <th>Feed</th>
            <th>Status</th>
            <th>Started</th>
            <th class="text-end">Duration</th>
            <th class="text-end">Feed size</th>
            <th class="text-end">Matched</th>
            <th class="text-end">Updated</th>
            <th class="text-end">Unchanged</th>
            <th class="text-end">Unmatched</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_logs.each do |log| %>
            <tr>
              <td class="align-middle"><%= log.friendly_name %></td>
              <td class="align-middle">
                <% badge_class = log.success? ? 'badge-pill-success' : log.failed? ? 'badge-pill-danger' : 'badge-pill-warning' %>
                <span class="badge <%= badge_class %> text-uppercase"><%= log.status %></span>
              </td>
              <td class="align-middle text-muted small"><%= log.started_at.strftime('%d %b %H:%M') %></td>
              <td class="align-middle text-end text-muted small">
                <%= log.duration_seconds ? "#{log.duration_seconds}s" : '—' %>
              </td>
              <td class="align-middle text-end"><%= log.total_in_feed || '—' %></td>
              <td class="align-middle text-end"><%= log.matched || '—' %></td>
              <td class="align-middle text-end <%= log.updated.to_i > 0 ? 'text-success fw-semibold' : '' %>">
                <%= log.updated || '—' %>
              </td>
              <td class="align-middle text-end text-muted"><%= log.skipped || '—' %></td>
              <td class="align-middle text-end <%= log.unmatched.to_i > 0 ? 'text-warning' : 'text-muted' %>">
                <%= log.unmatched || '—' %>
              </td>
              <td class="align-middle">
                <% if log.error_message.present? %>
                  <small class="text-danger"><%= log.error_message.truncate(80) %></small>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-body text-center text-muted py-5">
      <p class="mb-0">No sync runs recorded yet. Use the <strong>Run Now</strong> buttons above to trigger a sync.</p>
    </div>
  <% end %>
</div>
