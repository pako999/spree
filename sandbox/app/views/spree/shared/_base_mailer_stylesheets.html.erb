<style type="text/css" rel="stylesheet" media="all">
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap");

  /* Reset */
  body { width: 100% !important; height: 100%; margin: 0; -webkit-text-size-adjust: none; background-color: #F0F4F8; }
  a img { border: none; }
  td { word-break: break-word; }
  img { max-width: 100%; }

  .preheader {
    display: none !important; visibility: hidden; mso-hide: all;
    font-size: 1px; line-height: 1px; max-height: 0; max-width: 0; opacity: 0; overflow: hidden;
  }

  /* Typography */
  body, td, th { font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }

  h1 { margin-top: 0; color: #111827; font-size: 24px; font-weight: 700; text-align: left; line-height: 1.3; }
  h2 { margin-top: 0; color: #111827; font-size: 18px; font-weight: 600; text-align: left; }
  h3 { margin-top: 0; color: #374151; font-size: 13px; font-weight: 600; text-align: left; letter-spacing: 0.08em; text-transform: uppercase; }
  td, th { font-size: 15px; }
  p, ul, ol, blockquote { margin: 0.4em 0 1em; font-size: 15px; line-height: 1.65; color: #4B5563; }
  p.sub { font-size: 13px; color: #9CA3AF; }

  /* Utilities */
  .align-right  { text-align: right; }
  .align-left   { text-align: left; }
  .align-center { text-align: center; }

  /* Buttons */
  .button {
    background-color: #0062FF;
    border-top: 12px solid #0062FF; border-right: 22px solid #0062FF;
    border-bottom: 12px solid #0062FF; border-left: 22px solid #0062FF;
    display: inline-block; color: #FFFFFF !important; text-decoration: none;
    border-radius: 6px; font-weight: 600; font-size: 15px;
    box-shadow: 0 2px 6px rgba(0,98,255,0.35); -webkit-text-size-adjust: none; box-sizing: border-box;
  }
  .button--green {
    background-color: #10B981;
    border-top: 12px solid #10B981; border-right: 22px solid #10B981;
    border-bottom: 12px solid #10B981; border-left: 22px solid #10B981;
    box-shadow: 0 2px 6px rgba(16,185,129,0.35);
  }
  @media only screen and (max-width: 500px) {
    .button { width: 100% !important; text-align: center !important; }
  }

  /* Order status badge */
  .status-badge {
    display: inline-block; background-color: #ECFDF5; color: #059669;
    font-size: 12px; font-weight: 600; padding: 4px 10px; border-radius: 20px;
    letter-spacing: 0.05em; text-transform: uppercase; border: 1px solid #A7F3D0;
  }

  /* Info box */
  .info-box { background-color: #EFF6FF; border-left: 4px solid #0062FF; padding: 14px 18px; border-radius: 0 6px 6px 0; margin-bottom: 24px; }
  .info-box p { margin: 0; color: #1E40AF; font-size: 14px; }

  /* Attributes */
  .attributes { margin: 0 0 21px; }
  .attributes_content { background-color: #F9FAFB; padding: 16px 20px; border-radius: 8px; border: 1px solid #E5E7EB; }
  .attributes_item { padding: 0; }

  /* Purchase table */
  .purchase { width: 100%; margin: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; }
  .purchase_content { width: 100%; margin: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; }

  .purchase_item { padding: 16px 8px; color: #374151; font-size: 14px; line-height: 1.5; border-bottom: 1px solid #F3F4F6; }
  .purchase_item p { margin: 0; padding: 2px 0; }
  .purchase_item--additional { font-size: 12px; color: #9CA3AF; margin-top: 3px !important; }

  .purchase_image { padding: 8px; width: 80px; vertical-align: top; }
  .purchase_image img { width: 72px; height: 72px; object-fit: contain; border-radius: 8px; border: 1px solid #E5E7EB; background: #F9FAFB; }

  .purchase_heading { padding-bottom: 10px; border-bottom: 2px solid #E5E7EB; }
  .purchase_heading p { margin: 0; color: #9CA3AF; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }

  .purchase_footer { padding-top: 12px; border-top: 2px solid #E5E7EB; }
  .purchase_total { margin: 0; text-align: right; font-weight: 600; color: #111827; font-size: 14px; }
  .purchase_total--name { margin: 0; text-align: right; color: #6B7280; font-size: 13px; font-weight: 400; }
  .purchase_total--label { padding: 2px 12px 2px 0; }
  .purchase_total-col { vertical-align: bottom; }
  .purchase_grand_total { font-size: 16px !important; color: #111827 !important; }

  /* Wrapper */
  .email-wrapper { width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; background-color: #F0F4F8; }
  .email-content { width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; }

  /* Header */
  .email-masthead { padding: 0; text-align: center; }
  .email-masthead-inner { background-color: #0A1628; padding: 24px 40px; }
  .email-masthead_logo { width: auto; height: 48px; }
  .email-masthead_name { font-size: 18px; font-weight: 700; color: #FFFFFF; text-decoration: none; }

  /* Body */
  .email-body { width: 100%; margin: 0; padding: 0; -premailer-width: 100%; -premailer-cellpadding: 0; -premailer-cellspacing: 0; }
  .email-body_inner {
    width: 580px; margin: 0 auto; padding: 0;
    -premailer-width: 580px; -premailer-cellpadding: 0; -premailer-cellspacing: 0;
    background-color: #FFFFFF; border-radius: 0 0 8px 8px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .content-cell { padding: 36px 40px; }

  /* Footer */
  .email-footer {
    width: 580px; margin: 0 auto; padding: 0;
    -premailer-width: 580px; -premailer-cellpadding: 0; -premailer-cellspacing: 0;
    text-align: center;
  }
  .email-footer p { color: #9CA3AF; font-size: 12px; }
  .email-footer a { color: #6B7280; text-decoration: none; }
  .email-footer a:hover { text-decoration: underline; }

  .footer-inner { background-color: #0A1628; padding: 28px 40px; text-align: center; }
  .footer-tagline { color: #94A3B8; font-size: 13px; margin: 0 0 16px; }
  .footer-links { margin: 0 0 16px; }
  .footer-links a { color: #94A3B8; font-size: 12px; text-decoration: none; margin: 0 10px; }
  .footer-divider { border: none; border-top: 1px solid #1E293B; margin: 20px 0; }
  .footer-legal { color: #475569; font-size: 11px; margin: 0; line-height: 1.6; }

  .body-action { width: 100%; margin: 24px auto; padding: 0; text-align: center; }
  .body-sub { margin-top: 24px; padding-top: 24px; border-top: 1px solid #E5E7EB; }

  /* Trust bar */
  .trust-bar { background-color: #F9FAFB; border-top: 1px solid #E5E7EB; padding: 20px 40px; }
  .trust-item { text-align: center; padding: 0 12px; }
  .trust-item-icon { font-size: 20px; display: block; margin-bottom: 4px; }
  .trust-item-text { font-size: 11px; color: #6B7280; font-weight: 500; }

  /* Divider */
  .section-divider { border: none; border-top: 1px solid #E5E7EB; margin: 24px 0; }

  /* Mobile */
  @media only screen and (max-width: 620px) {
    .email-body_inner, .email-footer { width: 100% !important; border-radius: 0 !important; }
    .content-cell { padding: 24px 20px !important; }
    .email-masthead-inner { padding: 20px !important; }
    .footer-inner { padding: 24px 20px !important; }
    .trust-bar { padding: 16px 20px !important; }
    .purchase_image { width: 60px !important; }
    .purchase_image img { width: 52px !important; height: 52px !important; }
    h1 { font-size: 20px !important; }
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    body, .email-body, .email-body_inner, .email-content, .email-wrapper { background-color: #111827 !important; }
    .email-body_inner { background-color: #1F2937 !important; box-shadow: none !important; }
    h1, h2, h3 { color: #F9FAFB !important; }
    p, td, th { color: #D1D5DB !important; }
    .purchase_item { color: #D1D5DB !important; border-bottom-color: #374151 !important; }
    .purchase_total { color: #F9FAFB !important; }
    .purchase_heading { border-bottom-color: #374151 !important; }
    .purchase_footer { border-top-color: #374151 !important; }
    .trust-bar { background-color: #1F2937 !important; border-top-color: #374151 !important; }
    .attributes_content { background-color: #1F2937 !important; border-color: #374151 !important; }
    .info-box { background-color: #1E3A5F !important; }
    .section-divider { border-top-color: #374151 !important; }
    .purchase_image img { background-color: #374151 !important; border-color: #4B5563 !important; }
  }
</style>
