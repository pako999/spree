<div id="<%= dom_id(post) %>" class="h-full">
  <%= link_to spree.post_path(post), class: 'group flex flex-col h-full rounded-xl overflow-hidden border border-default bg-white shadow-sm hover:shadow-md transition-shadow duration-300', data: { turbo_frame: '_top' } do %>
    <%# Image %>
    <div class="relative overflow-hidden bg-gray-100 aspect-[16/9] shrink-0">
      <% if post.image.attached? %>
        <% begin %>
          <%= spree_image_tag(post.image, width: 600, height: 338,
                class: "w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500",
                loading: :lazy, alt: post.title) %>
        <% rescue %>
          <div class="w-full h-full bg-gray-200"></div>
        <% end %>
      <% else %>
        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      <% end %>
    </div>

    <%# Content %>
    <div class="flex flex-col flex-1 p-5">
      <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: #10D48E;"><%= local_time(post.published_at, "%B %-d, %Y") %></p>
      <h2 class="text-base font-bold leading-snug group-hover:text-accent transition-colors duration-200 flex-1"><%= post.title %></h2>
      <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-2"><%= post.shortened_description %></p>
      <div class="mt-4 pt-4 border-t border-default flex items-center justify-between">
        <span class="text-xs text-muted">Buying Guide</span>
        <span class="text-sm font-bold text-accent">Read →</span>
      </div>
    </div>
  <% end %>
</div>
