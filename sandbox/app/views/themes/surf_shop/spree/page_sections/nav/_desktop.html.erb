<% if section.blocks.any? %>
  <% section.blocks.includes(:links).each do |block| %>
    <% presenter = Spree::MegaNavPresenter.new(block) %>
    <% main_link = presenter.main_link %>
    <% next unless main_link.present? %>
    <div class="header--nav-item group" <%= block_attributes(block, allowed_styles: ['padding-top', 'padding-bottom']) %>>
      <%= link_to spree_storefront_resource_url(main_link.linkable || main_link),
          data: { title: main_link.label.downcase.strip, "nav-home": main_link.linkable.present? && main_link.linkable.is_a?(Spree::Pages::Homepage) ? "true" : nil },
          class: "shrink-0 menu-item header--nav-link px-4 py-1",
          target: main_link.open_in_new_tab.presence && "_blank",
          rel: main_link.open_in_new_tab.presence && "noopener noreferrer" do %>
        <span class="group-hover:border-b-[1.5px] group-hover:border-b-accent"><%= main_link.label %></span>
      <% end %>
      <% if presenter.columns.any? %>
        <div class="w-full bg-transparent invisible absolute translate-y-[10%] group-hover:translate-y-0 left-0 group-hover:opacity-100 opacity-0 group-hover:visible transition-none border-default border-b duration-150 ease-in block pointer-events-none group-hover:pointer-events-auto z-10 header--mega-nav-container" style="--bottom-padding: <%= section.preferred_bottom_padding %>px; --top-without-bottom-padding: calc(100% - var(--bottom-padding)); padding-top: calc(var(--bottom-padding) + var(--section--border-bottom-width)); top: var(--top-without-bottom-padding);">
          <div class="bg-white border-t border-gray-100 shadow-xl">
            <div class="page-container">
              <div class="flex gap-0">
                <%# Left accent bar tied to the category %>
                <div class="w-1 shrink-0 bg-accent"></div>

                <div class="flex-1 py-7 px-6 grid gap-x-8 gap-y-0" style="grid-template-columns: repeat(<%= [presenter.columns.size, 4].min %>, minmax(0,1fr));">
                  <% presenter.columns.each_with_index do |column, col_idx| %>
                    <div class="flex flex-col <%= col_idx > 0 ? 'border-l border-gray-100 pl-8' : '' %>">
                      <%# Column heading — links to the parent category %>
                      <div class="mb-4 pb-3 border-b border-gray-100">
                        <% if column.view_all_linkable.present? %>
                          <%= link_to spree_storefront_resource_url(column.view_all_linkable),
                              class: "text-xs font-bold tracking-[0.12em] uppercase text-gray-800 hover:text-accent transition-colors flex items-center gap-1.5" do %>
                            <%= column.title %>
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                          <% end %>
                        <% else %>
                          <span class="text-xs font-bold tracking-[0.12em] uppercase text-gray-800"><%= column.title %></span>
                        <% end %>
                      </div>

                      <%# Subcategory links %>
                      <ul class="space-y-0.5">
                        <% column.links.each do |link| %>
                          <li>
                            <%= page_builder_link_to link,
                                data: { title: link.label.downcase.strip },
                                class: "group/link flex items-center gap-2 py-1.5 px-2 rounded text-sm text-gray-600 hover:text-accent hover:bg-accent/5 transition-colors !normal-case header--nav-link",
                                target: link.open_in_new_tab.presence && "_blank",
                                rel: link.open_in_new_tab.presence && "noopener noreferrer" do %>
                              <span class="w-1 h-1 rounded-full bg-gray-300 group-hover/link:bg-accent transition-colors shrink-0"></span>
                              <span class="font-medium"><%= link.label %></span>
                            <% end %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>
                </div>

                <%# Featured taxon image — right side %>
                <% if block.try(:featured_taxon) %>
                  <% cache spree_storefront_base_cache_scope.call(block.featured_taxon) do %>
                    <% if block.featured_taxon.image.attached? && block.featured_taxon.image.variable? %>
                      <div class="w-56 shrink-0 border-l border-gray-100">
                        <%= link_to spree_storefront_resource_url(block.featured_taxon), class: "flex flex-col h-full" do %>
                          <%= spree_image_tag(block.featured_taxon.image, width: 224, height: 280, class: 'w-full h-full object-cover', loading: :lazy, alt: block.featured_taxon.name) %>
                          <span class="py-3 px-4 bg-accent block text-xs font-bold tracking-widest uppercase text-center header--mega-nav-featured-taxon-title"><%= Spree.t(:explore_taxon, taxon_name: block.featured_taxon.name) %></span>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <% section.links.each do |link| %>
    <%= link_to spree_storefront_resource_url(link.linkable || link),
        data: { title: link.label.downcase.strip, "nav-home": link.linkable.present? && link.linkable.is_a?(Spree::Pages::Homepage) ? "true" : nil },
        class: "shrink-0 menu-item header--nav-link px-4 py-1 focus:mx-0 focus:px-4",
        target: link.open_in_new_tab.presence && "_blank",
        rel: link.open_in_new_tab.presence && "noopener noreferrer",
        **link_attributes(link, as_html: false) do %>
      <span><%= link.label %></span>
    <% end %>
  <% end %>
<% end %>
