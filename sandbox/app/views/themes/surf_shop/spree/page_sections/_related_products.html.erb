<% loaded ||= false %>
<% product ||= @product %>

<%
  # Always show products from the same category as the current product.
  # Use a two-step approach: first get IDs (fast), then load with includes.
  products = []
  if product.present?
    taxons = product.taxons.where.not(parent_id: nil).order(depth: :desc)
    primary_taxon = taxons.first
    if primary_taxon.present?
      limit = section&.preferred_max_products_to_show || 10
      product_ids = current_store.products.active(current_currency)
                      .in_taxon(primary_taxon)
                      .where.not(id: product.id)
                      .distinct.limit(limit).pluck(:id)
      # Fall back to parent taxon if too few results
      if product_ids.length < 4 && primary_taxon.parent.present?
        product_ids = current_store.products.active(current_currency)
                        .in_taxon(primary_taxon.parent)
                        .where.not(id: product.id)
                        .distinct.limit(limit).pluck(:id)
      end
      if product_ids.any?
        products = Spree::Product.where(id: product_ids)
                     .includes(master: [:prices], variants: [:prices, { option_values: :option_type }], option_types: [])
                     .preload_associations_lazily
      end
    end
    loaded = true
  end
%>

<% if section && loaded && products.present? %>
  <div style="<%= section_styles(section) %>" class="animate-fadeIn">
    <div class="page-container">
      <%= render partial: 'spree/products/swiper', locals: {
        section: section,
        products: products,
        heading: section.preferred_heading,
        arrows_on_top: true
      } %>
    </div>
  </div>
<% end %>
