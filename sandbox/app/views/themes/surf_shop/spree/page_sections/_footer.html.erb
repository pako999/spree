<% cache_unless page_builder_enabled?, [*spree_storefront_base_cache_scope.call(section), current_store] do %>
  <footer id='footer' class="mt-footer"
    <% unless current_theme_preview %>
    data-turbo-permanent
    <% end %>>

    <%# === Value Propositions Strip === %>
    <div class="mt-footer-value-props">
      <div class="page-container">
        <div class="mt-value-props-grid">
          <div class="mt-value-prop">
            <span class="mt-value-icon">🚚</span>
            <div>
              <strong>Free Shipping</strong>
              <span>Starting from 99 €</span>
            </div>
          </div>
          <div class="mt-value-prop">
            <span class="mt-value-icon">↩️</span>
            <div>
              <strong>Free Returns</strong>
              <span>30 days to reconsider</span>
            </div>
          </div>
          <div class="mt-value-prop">
            <span class="mt-value-icon">🛡️</span>
            <div>
              <strong>Secure Payments</strong>
              <span>100% secure checkout</span>
            </div>
          </div>
          <div class="mt-value-prop">
            <span class="mt-value-icon">⭐</span>
            <div>
              <strong>+6000 Happy Customers</strong>
              <span>Trusted since 2003</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# === Main Footer Columns === %>
    <div class="mt-footer-main">
      <div class="page-container">
        <div class="mt-footer-grid">
          <%# Column 1: Company / Logo %>
          <div class="mt-footer-col">
            <div class="mt-footer-logo">
              <a href="/">
                <img src="/images/surfstore-logo.webp" alt="Surf-store.com" style="max-height:38px;width:auto;filter:brightness(0) invert(1)">
              </a>
            </div>
            <p class="mt-footer-company-text mt-footer-company-address" style="margin-bottom:12px">Your trusted water sports shop</p>
            <div style="display:flex;flex-direction:column;gap:5px">
              <span style="font-size:0.75rem;color:rgba(255,255,255,0.5);display:flex;align-items:center;gap:6px">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Since 2003 — over 20 years of experience
              </span>
              <span style="font-size:0.75rem;color:rgba(255,255,255,0.5);display:flex;align-items:center;gap:6px">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                More than 2.000 products
              </span>
            </div>
          </div>

          <%# Helper to render links for a block %>
          <%
            render_block_links = ->(block) do
              block.links.map do |link|
                link_href = if link.url.present?
                  link.url
                elsif link.linkable.present?
                  case link.linkable_type
                  when 'Spree::Taxon'  then "/t/#{link.linkable.permalink}"
                  when 'Spree::Policy' then "/policies/#{link.linkable.slug}"
                  when 'Spree::Page'
                    case link.linkable.type
                    when 'Spree::Pages::ShopAll'  then '/products'
                    when 'Spree::Pages::Account'  then '/account'
                    when 'Spree::Pages::Wishlist' then '/wishlist'
                    when 'Spree::Pages::Homepage' then '/'
                    when 'Spree::Pages::PostList' then '/posts'
                    when 'Spree::Pages::Cart'     then '/cart'
                    when 'Spree::Pages::Login'    then '/login'
                    else link.linkable.slug.present? ? "/#{link.linkable.slug}" : '/'
                    end
                  else link.url.to_s
                  end
                else
                  '#'
                end
                [link, link_href]
              end
            end

            blocks_by_label = section.blocks.includes(:links).index_by { |b| b.preferred_label.to_s.downcase }
            shop_block    = blocks_by_label['shop']
            account_block = blocks_by_label['account']
            other_blocks  = section.blocks.includes(:links).reject { |b|
              ['shop','account','info'].include?(b.preferred_label.to_s.downcase)
            }
          %>

          <%# SHOP column %>
          <% if shop_block %>
            <nav class="mt-footer-col" aria-label="Shop">
              <h4 class="mt-footer-heading"><%= shop_block.preferred_label %></h4>
              <ul class="mt-footer-links">
                <% render_block_links.call(shop_block).each do |link, href| %>
                  <li><a href="<%= href %>" class="mt-footer-link"<%= ' target="_blank" rel="noopener noreferrer"'.html_safe if link.open_in_new_tab %>><%= link.label %></a></li>
                <% end %>
              </ul>
            </nav>
          <% end %>

          <%# BRANDS column %>
          <div class="mt-footer-col">
            <nav aria-label="Brands">
              <h4 class="mt-footer-heading">Brands</h4>
              <ul class="mt-footer-links">
                <li><a href="/t/brands/cabrinha" class="mt-footer-link">Cabrinha</a></li>
                <li><a href="/t/brands/duotone-kiteboarding" class="mt-footer-link">Duotone Kiteboarding</a></li>
                <li><a href="/t/brands/duotone-windsurfing" class="mt-footer-link">Duotone Windsurfing</a></li>
                <li><a href="/t/brands/duotone-wing-foiling" class="mt-footer-link">Duotone Wing Foiling</a></li>
                <li><a href="/t/brands/duotone-foiling-and-electric" class="mt-footer-link">Duotone Foiling &amp; Electric</a></li>
                <li><a href="/t/brands/duotone-apparel" class="mt-footer-link">Duotone Apparel</a></li>
                <li><a href="/t/brands/fanatic-sup" class="mt-footer-link">Fanatic SUP</a></li>
                <li><a href="/t/brands/fanatic-windsurfing" class="mt-footer-link">Fanatic Windsurfing</a></li>
                <li><a href="/t/brands/gaastra" class="mt-footer-link">Gaastra</a></li>
                <li><a href="/t/brands/ion-water" class="mt-footer-link">ION Water</a></li>
                <li><a href="/t/brands/jp-australia" class="mt-footer-link">JP Australia</a></li>
                <li><a href="/t/brands/neilpryde" class="mt-footer-link">Neilpryde</a></li>
                <li><a href="/t/brands/nobile" class="mt-footer-link">Nobile</a></li>
                <li><a href="/t/brands/point7" class="mt-footer-link">Point7</a></li>
                <li><a href="/t/brands/tabou" class="mt-footer-link">Tabou</a></li>
                <li><a href="/t/brands/woo-sports" class="mt-footer-link">WOO Sports</a></li>
              </ul>
            </nav>
          </div>

          <%# MY ACCOUNT column %>
          <nav class="mt-footer-col" aria-label="My Account">
            <h4 class="mt-footer-heading">My Account</h4>
            <ul class="mt-footer-links">
              <li><a href="/account/orders" class="mt-footer-link">My Orders</a></li>
              <li><a href="/wishlist" class="mt-footer-link">Favorites</a></li>
              <li><a href="/account" class="mt-footer-link">My Profile</a></li>
              <li><a href="/users/sign_in" class="mt-footer-link">Login</a></li>
              <li><a href="/users/sign_up" class="mt-footer-link">Register</a></li>
            </ul>
          </nav>

          <%# INFO column %>
          <nav class="mt-footer-col" aria-label="Info">
            <h4 class="mt-footer-heading">Info</h4>
            <ul class="mt-footer-links">
              <li><a href="/policies/therms-and-conditions" class="mt-footer-link">Terms &amp; Conditions</a></li>
              <li><a href="/policies/shipping-policy" class="mt-footer-link">Shipping Policy</a></li>
              <li><a href="/policies/returns-refund-policy" class="mt-footer-link">Shipping &amp; Refunds</a></li>
              <li><a href="/policies/privacy-policy" class="mt-footer-link">Privacy Policy</a></li>
              <li><a href="/policies/about-us" class="mt-footer-link">About Us</a></li>
              <li><a href="/policies/contact" class="mt-footer-link">Contact</a></li>
            </ul>
          </nav>

          <%# Community / Social column %>
          <div class="mt-footer-col">
            <h4 class="mt-footer-heading"><%= Spree.t(:follow_us) %></h4>
            <div class="mt-social-icons">
              <% cache spree_storefront_base_cache_scope.call(current_store) do %>
                <% Spree::Store::SUPPORTED_SOCIAL_NETWORKS.each do |media| %>
                  <% if current_store.send(media).present? %>
                    <%= link_to current_store.send("#{media}_link"), class: 'mt-social-icon' do %>
                      <%= render "spree/shared/icons/#{media.gsub('_', '-')}" %>
                    <% end %>
                  <% end %>
                <% end %>
              <% end %>
            </div>
            <h4 class="mt-footer-heading mt-4">Payment Methods</h4>
            <div class="mt-payment-icons" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="30" viewBox="0 0 48 30" fill="none" role="img" aria-label="Visa"><rect width="48" height="30" rx="4" fill="#fff"/><path d="M19.5 20.3h-3l1.9-11.6h3l-1.9 11.6Zm12.8-11.3c-.6-.2-1.5-.5-2.7-.5-3 0-5.1 1.5-5.1 3.7 0 1.6 1.5 2.5 2.6 3.1 1.2.6 1.6.9 1.6 1.4 0 .8-.9 1.1-1.8 1.1-1.2 0-1.9-.2-2.9-.6l-.4-.2-.4 2.6c.7.3 2.1.6 3.5.6 3.2 0 5.2-1.5 5.2-3.8 0-1.3-.8-2.2-2.5-3.1-1-.5-1.7-.8-1.7-1.4 0-.5.5-.9 1.7-.9.9 0 1.6.2 2.2.4l.3.1.4-2.5Zm7.9 0h-2.3c-.7 0-1.3.2-1.6.9l-4.5 10.4h3.2l.6-1.7h3.9l.4 1.7H43L40.2 9Zm-3.7 7.5 1.2-3.2.5-1.3.3 1.3.7 3.2h-2.7ZM16.3 9l-2.8 7.9-.3-1.5c-.5-1.7-2.2-3.6-4-4.5l2.7 9.4h3.2L19.5 9h-3.2Z" fill="#1A1F71"/><path d="M10.7 9H5.9l-.1.3c3.8.9 6.3 3.2 7.3 5.9l-1.1-5.3c-.2-.7-.7-.9-1.3-.9Z" fill="#F7A600"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="30" viewBox="0 0 48 30" fill="none" role="img" aria-label="Mastercard"><rect width="48" height="30" rx="4" fill="#fff"/><circle cx="19" cy="15" r="9" fill="#EB001B"/><circle cx="29" cy="15" r="9" fill="#F79E1B"/><path d="M24 8.3a9 9 0 0 1 3.3 6.7 9 9 0 0 1-3.3 6.7A9 9 0 0 1 20.7 15 9 9 0 0 1 24 8.3Z" fill="#FF5F00"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="30" viewBox="0 0 48 30" fill="none" role="img" aria-label="Apple Pay"><rect width="48" height="30" rx="4" fill="#fff"/><path d="M15.2 10.2c-.4.5-1 .8-1.6.8-.1-.6.2-1.3.5-1.7.4-.5 1-.8 1.5-.8.1.7-.2 1.3-.4 1.7Zm.4.9c-.9 0-1.6.5-2 .5-.5 0-1.1-.5-1.9-.5-.9 0-1.8.5-2.3 1.4-1 1.7-.3 4.2.7 5.6.5.7 1 1.4 1.8 1.4.7 0 1-.5 1.8-.5.9 0 1.1.5 1.9.5.8 0 1.2-.7 1.7-1.4.5-.8.7-1.5.7-1.6-1-.4-1.2-1.9-1.2-2 0-1.4 1.1-2 1.2-2.1-.7-1-1.7-1.3-2.1-1.3l-.3-.1Zm7.4.3v6.7h1v-2.3h1.5c1.4 0 2.3-.9 2.3-2.2s-.9-2.2-2.3-2.2H23Zm1 .9h1.2c1 0 1.5.5 1.5 1.3 0 .9-.5 1.4-1.5 1.4H24v-2.7Zm5 5c.6 0 1.2-.3 1.5-.8h0v.8h1V14c0-1-.8-1.7-2-1.7-1.1 0-1.9.6-2 1.5h1c.1-.4.5-.7 1-.7.6 0 1 .3 1 .9v.4l-1.3.1c-1.2.1-1.9.6-1.9 1.5 0 .9.7 1.5 1.7 1.5Zm.3-.8c-.5 0-.9-.3-.9-.7 0-.5.3-.7 1-.8l1.1-.1v.4c0 .7-.5 1.2-1.2 1.2Zm3.4 2.7c1 0 1.4-.4 1.8-1.4l1.7-4.7h-1l-1.1 3.6h0l-1.2-3.6h-1l1.7 4.5v.1c-.2.5-.4.7-.9.7h-.3v.8h.3Z" fill="#000"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="30" viewBox="0 0 48 30" fill="none" role="img" aria-label="Google Pay"><rect width="48" height="30" rx="4" fill="#fff"/><path d="M22.7 15.3v2.9h-.9v-7h2.5c.6 0 1.1.2 1.6.6.4.4.6.9.6 1.5 0 .6-.2 1.1-.6 1.5-.4.4-1 .6-1.6.6h-1.6Zm0-3.3v2.5h1.6c.4 0 .7-.1 1-.4.3-.3.4-.6.4-.9s-.1-.6-.4-.9c-.3-.3-.6-.4-1-.4h-1.6Z" fill="#3C4043"/><path d="M28.4 13.3c.7 0 1.2.2 1.6.5.4.4.6.9.6 1.5v3h-.9v-.7h0c-.4.5-.9.8-1.5.8-.5 0-1-.2-1.4-.5-.4-.3-.5-.7-.5-1.2 0-.5.2-.9.5-1.2.4-.3.8-.4 1.4-.4.5 0 .9.1 1.2.3v-.2c0-.3-.1-.6-.4-.8-.2-.3-.5-.4-.8-.4-.5 0-.9.2-1.1.6l-.8-.5c.4-.5.9-.8 1.6-.8Zm-1.1 3.4c0 .2.1.4.3.6.2.2.5.3.7.3.4 0 .8-.2 1-.5.3-.3.5-.6.5-1-.3-.2-.6-.3-1.1-.3-.4 0-.7.1-.9.3-.3.2-.5.4-.5.6Z" fill="#3C4043"/><path d="M33.8 13.5l-3 6.7h-.9l1.1-2.4-2-4.3h1l1.4 3.3h0l1.4-3.3h1Z" fill="#3C4043"/><path d="M19.7 15c0-.3 0-.5-.1-.8h-3.7v1.5h2.1c-.1.5-.3.9-.7 1.2v1h1.2c.7-.6 1.2-1.6 1.2-2.9Z" fill="#4285F4"/><path d="M15.9 18c1 0 1.8-.3 2.4-.9l-1.2-1c-.3.2-.7.4-1.2.4-.9 0-1.7-.6-2-1.5h-1.2v1c.6 1.2 1.8 2 3.2 2Z" fill="#34A853"/><path d="M13.9 15c-.1-.3-.1-.5-.1-.8s0-.5.1-.8v-1h-1.2c-.3.5-.4 1-.4 1.6s.1 1.1.4 1.6l1.2-.6Z" fill="#FBBC04"/><path d="M15.9 12c.5 0 1 .2 1.4.5l1-1c-.6-.6-1.5-.9-2.4-.9-1.3 0-2.5.8-3.2 2l1.2 1c.3-.9 1.1-1.6 2-1.6Z" fill="#EA4335"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="30" viewBox="0 0 48 30" fill="none" role="img" aria-label="Bank Transfer"><rect width="48" height="30" rx="4" fill="#fff"/><path d="M24 7l8 5v1H16v-1l8-5Zm-6 7h2v7h-2v-7Zm4 0h2v7h-2v-7Zm4 0h2v7h-2v-7Zm4 0h2v7h-2v-7Zm-12 0h2v7h-2v-7ZM15 22h18v2H15v-2Z" fill="#555"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# === Copyright Bar === %>
    <div class="mt-footer-copyright">
      <div class='page-container'>
        <div class="mt-copyright-inner">
          <span>© <%= Time.now.year %> <a href='/'><%= current_store.name %></a>. <%= Spree.t(:all_rights_reserved) %>.</span>
          <span class="mt-copyright-links">
            <a href="/policies/therms-and-conditions">Terms & Conditions</a>
            <span>·</span>
            <a href="/policies/privacy-policy">Privacy Policy</a>
            <span>·</span>
            Powered by <a href='https://spreecommerce.org' target="_blank" rel="follow">Spree Commerce</a>
          </span>
        </div>
      </div>
    </div>
  </footer>
<% end %>
