<div style="<%= section_styles(section) %>">
  <%# Hero — full-width image with gradient overlay, title at bottom %>
  <% if post.image.attached? %>
    <div class="relative w-full overflow-hidden" style="height: 520px; max-height: 55vh;">
      <% begin %>
        <%= spree_image_tag(post.image, width: 1440, height: 520,
              class: 'absolute inset-0 w-full h-full object-cover object-center',
              loading: :eager, alt: post.title) %>
      <% rescue; end %>
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0.78) 100%);"></div>
      <div class="absolute bottom-0 left-0 right-0 pb-10">
        <div class="page-container">
          <div class="max-w-3xl">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight"><%= post.title %></h1>
            <% if post.published? %>
              <div class="mt-3 flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.72);">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <%= local_time(post.published_at, '%B %-d, %Y') %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="page-container pt-12 pb-2">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-bold leading-tight"><%= post.title %></h1>
        <% if post.published? %>
          <div class="mt-3 text-sm text-muted flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <%= local_time(post.published_at, '%B %-d, %Y') %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="page-container">
    <div class="max-w-3xl py-10 md:py-14">
      <div style="width: 48px; height: 3px; background-color: #10D48E; border-radius: 2px; margin-bottom: 2rem;"></div>
      <div class="post-details-content prose prose-lg max-w-none"><%= post.content %></div>
    </div>
  </div>
</div>

<%= render 'spree/posts/json_ld', post: post %>
