<div style="<%= section_styles(section) %>">
  <%# Hero image — full width above the content container %>
  <% if post.image.attached? %>
    <div class="w-full overflow-hidden" style="max-height: 480px;">
      <% begin %>
        <%= spree_image_tag(post.image, width: 1200, height: 480,
              class: 'w-full object-cover object-center',
              style: 'max-height: 480px;',
              loading: :eager, alt: post.title) %>
      <% rescue; end %>
    </div>
  <% end %>

  <div class="page-container">
    <div class="flex flex-col max-w-3xl m-auto mt-10">
      <h1 class="text-3xl font-bold mt-4 leading-tight"><%= post.title %></h1>

      <% if post.published? %>
        <div class="mt-3 text-sm text-gray-500 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= local_time(post.published_at, '%B %e, %Y') %>
        </div>
      <% end %>

      <div class="mt-8 post-details-content prose prose-lg max-w-none"><%= post.content %></div>
    </div>
  </div>
</div>

<%= render 'spree/posts/json_ld', post: post %>
