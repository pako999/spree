<% cache spree_storefront_base_cache_scope.call(current_store) do %>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": <%= current_store.name.to_json.html_safe %>,
      "legalName": "Sport group d.o.o.",
      "url": <%= current_store.formatted_url_or_custom_domain.to_json.html_safe %>,
      "description": "Europe's premier water sports shop for kiteboarding, windsurfing, wingsurfing, SUP and wetsuits. Official dealer of Duotone, ION, Fanatic, Neilpryde, Cabrinha, JP, Point7, Tabou, Gaastra and Nobile. Fast shipping across Europe.",
      "foundingDate": "2003",
      "email": <%= current_store.customer_support_email.to_json.html_safe %>,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Osojnikova 4",
        "addressLocality": "Maribor",
        "postalCode": "2000",
        "addressCountry": "SI"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": <%= current_store.customer_support_email.to_json.html_safe %>,
        "availableLanguage": ["English", "Slovenian"]
      },
      <% if current_store.logo && current_store.logo&.attached? && current_store.logo&.variable? %>
      "logo": {
        "@type": "ImageObject",
        "url": <%= spree_image_url(current_store.logo, width: 250, height: 250).to_json.html_safe %>
      },
      <% end %>
      "sameAs": <%= (current_store.social_links + [
        "https://www.linkedin.com/company/surf-store",
        "https://www.facebook.com/surfstoredotcom"
      ]).uniq.to_json.html_safe %>
    }
  </script>

  <%# LocalBusiness / SportingGoodsStore — only on homepage %>
  <% if current_page.is_a?(Spree::Pages::Homepage) %>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SportingGoodsStore",
        "name": <%= current_store.name.to_json.html_safe %>,
        "url": <%= current_store.formatted_url_or_custom_domain.to_json.html_safe %>,
        "description": "Water sports equipment retailer in Maribor, Slovenia. Specialist in kitesurfing, windsurfing, wingsurfing, SUP, e-foil and wetsuits. Official dealer since 2003.",
        "email": <%= current_store.customer_support_email.to_json.html_safe %>,
        "foundingDate": "2003",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Osojnikova 4",
          "addressLocality": "Maribor",
          "postalCode": "2000",
          "addressCountry": "SI"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "46.5547",
          "longitude": "15.6459"
        },
        "priceRange": "€€€",
        "currenciesAccepted": "EUR",
        "paymentAccepted": "Credit Card, Bank Transfer",
        "areaServed": "Europe",
        <% if current_store.logo && current_store.logo&.attached? && current_store.logo&.variable? %>
        "image": <%= spree_image_url(current_store.logo, width: 500, height: 500).to_json.html_safe %>,
        <% end %>
        "sameAs": <%= current_store.social_links.to_json.html_safe %>
      }
    </script>
  <% end %>

  <%# WebSite + SearchAction — on all pages %>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": <%= current_store.name.to_json.html_safe %>,
      "url": <%= current_store.formatted_url_or_custom_domain.to_json.html_safe %>,
      "description": "Europe's premier water sports shop — kiteboarding, windsurfing, wingsurfing, SUP and wetsuits.",
      "inLanguage": "en",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "<%= current_store.formatted_url_or_custom_domain %>/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  </script>
<% end %>
